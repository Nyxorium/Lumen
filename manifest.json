{
  "manifest_version": 3,
  "name": "Lumen",
  "version": "0.1.0",
  "description": "Surfaces pronouns from AT Protocol profiles on Bluesky.",

  "icons": {
    "48": "icons/PIA09178.png",
    "96": "icons/PIA09178.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Lumen"
  },

  "content_scripts": [
    {
      "matches": ["https://bsky.app/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],

  "permissions": ["storage"],

  "host_permissions": ["<all_urls>"],

  "browser_specific_settings": {
    "gecko": {
      "id": "lumen@nyxorium",
      "strict_min_version": "109.0"
    }
  }
}